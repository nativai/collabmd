{
  "name": "collabmd",
  "version": "0.1.34",
  "type": "module",
  "description": "Collaborative markdown vault — like Obsidian, but online. Serve any directory of markdown files for realtime collaborative editing.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andes90/collabmd.git"
  },
  "homepage": "https://github.com/andes90/collabmd#readme",
  "bugs": {
    "url": "https://github.com/andes90/collabmd/issues"
  },
  "files": [
    "README.md",
    "bin/",
    "dist/",
    "docker-compose.yml",
    "scripts/cloudflare-tunnel.mjs",
    "scripts/local-plantuml-compose.mjs",
    "server.js",
    "src/"
  ],
  "bin": {
    "collabmd": "./bin/collabmd.js"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "vite build",
    "capture:readme-assets": "node scripts/capture-readme-assets.mjs",
    "check": "npm run lint && npm run test:guardrails && npm run test:unit && npm run test:browser",
    "dev:client": "vite",
    "dev:server": "node bin/collabmd.js --no-tunnel",
    "homebrew:formula": "node scripts/render-homebrew-formula.mjs",
    "lint": "eslint .",
    "plantuml:up": "node scripts/local-plantuml-compose.mjs up",
    "plantuml:down": "node scripts/local-plantuml-compose.mjs down",
    "start": "npm run build && node bin/collabmd.js",
    "start:local-plantuml": "npm run build && node bin/collabmd.js --local-plantuml",
    "start:prod": "node bin/collabmd.js",
    "test": "npm run test:unit && npm run test:browser && npm run test:e2e",
    "test:browser": "vitest run --config vitest.config.mjs --browser=chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:guardrails": "node --test tests/node/architecture-boundaries.test.js tests/node/facade-structure.test.js tests/node/style-system-guardrails.test.js",
    "test:unit": "npm run build && node --test --test-force-exit tests/node/*.test.js",
    "tunnel": "node scripts/cloudflare-tunnel.mjs"
  },
  "keywords": [
    "markdown",
    "collaboration",
    "obsidian",
    "vault",
    "yjs",
    "mermaid",
    "cli"
  ],
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@excalidraw/excalidraw": "0.18.0-4a5c9e9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@turbodocx/html-to-docx": "^1.20.1",
    "archiver": "^7.0.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lib0": "^0.2.117",
    "lit-html": "^3.3.2",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.13.0",
    "openid-client": "^6.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "overrides": {
    "@excalidraw/excalidraw": {
      "@radix-ui/react-tabs": "1.1.13"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
