{
  "name": "collabmd",
  "version": "1.0.0",
  "type": "module",
  "description": "Realtime collaborative markdown editor with Mermaid diagram support",
  "scripts": {
    "build": "node scripts/build-client.mjs",
    "check": "npm run build && node --check src/server/index.js && node --check src/server/create-app-server.js && node --check scripts/build-client.mjs && node --check scripts/cloudflare-tunnel.mjs && node --check scripts/start-test-server.mjs && node --check scripts/start-with-cloudflare-tunnel.mjs && node --check playwright.config.js",
    "start": "npm run build && node src/server/index.js",
    "start:prod": "node src/server/index.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:unit": "node --test --test-force-exit tests/node/*.test.js",
    "tunnel": "node scripts/cloudflare-tunnel.mjs",
    "start:tunnel": "node scripts/start-with-cloudflare-tunnel.mjs"
  },
  "keywords": [
    "markdown",
    "collaboration",
    "yjs",
    "mermaid"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.0",
    "highlight.js": "^11.11.1",
    "lib0": "^0.2.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.0",
    "ws": "^8.0.0",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3"
  }
}
