NODE_ENV=production
HOST=0.0.0.0
PORT=1234
AUTH_STRATEGY=none
AUTH_PASSWORD=
AUTH_SESSION_COOKIE_NAME=collabmd_auth
AUTH_SESSION_SECRET=
AUTH_SESSION_MAX_AGE_MS=
PUBLIC_BASE_URL=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_ALLOWED_EMAILS=
AUTH_OIDC_ALLOWED_DOMAINS=
BASE_PATH=
COLLABMD_EMBED_PARENTS=
WS_BASE_PATH=/ws
PUBLIC_WS_BASE_URL=
PLANTUML_SERVER_URL=https://www.plantuml.com/plantuml
COLLABMD_WIKI_LINK_AUTO_CREATE=true
COLLABMD_GIT_REPO_URL=
COLLABMD_GIT_SSH_PRIVATE_KEY_FILE=
COLLABMD_GIT_SSH_PRIVATE_KEY_B64=
COLLABMD_GIT_SSH_KNOWN_HOSTS_FILE=
COLLABMD_GIT_USER_NAME=
COLLABMD_GIT_USER_EMAIL=
PERSISTENCE_DIR=data/rooms
ROOM_NAMESPACE=collabmd

# File watcher (live-reload of external edits). The watcher reflects out-of-band
# changes (a second editor, vscode-web, SSH, agents) into open files and the tree.
# Set to `false` to disable live-reload entirely (editing/saving still work).
COLLABMD_FILE_WATCHER_ENABLED=true
# Max inotify watches to place. Recursive fs.watch places one watch PER DIRECTORY,
# so very large vaults would exhaust the kernel limit and crash; vaults with more
# directories than this cap switch to a bounded, navigation-scoped watch strategy
# (root + open files + a top-N sweep) that never exceeds the cap. Smaller vaults are
# unaffected. Default 4096 (well under the common 8192 kernel default).
COLLABMD_MAX_WATCHES=4096
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_HEADERS_TIMEOUT_MS=60000
HTTP_REQUEST_TIMEOUT_MS=30000
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_BUFFERED_AMOUNT_BYTES=16777216
WS_MAX_PAYLOAD_BYTES=16777216
CLOUDFLARED_BIN=cloudflared
TUNNEL_TARGET_HOST=127.0.0.1
TUNNEL_TARGET_PORT=1234
TUNNEL_TARGET_URL=
CLOUDFLARED_EXTRA_ARGS=

# docker compose helpers
COLLABMD_IMAGE=collabmd:local
HOST_VAULT_DIR=./data/vault
COLLABMD_HOST_PORT=1234
PLANTUML_HOST_PORT=18080
